{
    "Elsa": {
      "MongoDb": {
        "ConnectionString": "mongodb://localhost:27017",
        "DatabaseName": "elsa"
      },
    },
    "JavaScript": {
      "AllowClrAccess": true,
      "AllowConfigurationAccess": true,
      "MaxExecutionTime": "00:00:05",
      "EnableDebugging": false
    },

    "Liquid": {
      "EnableSafeMode": false
      // Liquid has very few bindable properties.
      // Most configuration is done via FluidOptions in code.
    },
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  }
